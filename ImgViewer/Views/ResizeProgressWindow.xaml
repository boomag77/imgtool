<Window x:Class="ImgViewer.Views.ResizeProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch resize progress"
        Height="210"
        Width="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="0"
                   Text="Preparing..."
                   Margin="0,0,0,8"
                   TextWrapping="Wrap"/>

        <ProgressBar x:Name="MainProgressBar"
                     Grid.Row="1"
                     Height="18"
                     Minimum="0"
                     Maximum="100"
                     Value="0"/>

        <TextBlock x:Name="CurrentFileTextBlock"
                   Grid.Row="2"
                   Margin="0,8,0,0"
                   Text=""
                   TextWrapping="Wrap"/>

        <Button x:Name="CancelButton"
                Grid.Row="3"
                Content="Cancel"
                Width="100"
                HorizontalAlignment="Right"
                Margin="0,10,0,0"
                Click="CancelButton_Click"/>
    </Grid>
</Window>
